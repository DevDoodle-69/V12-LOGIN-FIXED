#!/bin/bash

# V12 FCA Bot Launcher Script
# Starts the bot with proper dependency management and credential checking

clear
echo "========================================"
echo "   V12 FCA Bot - Startup System"
echo "   Authenticating with v12-account.txt"
echo "========================================"
echo ""

# Check if node_modules exists
if [ ! -d "node_modules" ]; then
    echo "[INFO] Installing dependencies..."
    npm install
    echo ""
fi

# Check if v12-account.txt exists
if [ ! -f "v12-account.txt" ]; then
    echo "[WARNING] v12-account.txt not found"
    echo "         Bot will attempt email/password login from config.json"
    echo ""
fi

# Start the bot
echo "[INFO] Starting V12 FCA Bot..."
echo ""
node index.js
